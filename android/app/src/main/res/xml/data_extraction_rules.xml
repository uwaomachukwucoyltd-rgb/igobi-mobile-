<?xml version="1.0" encoding="utf-8"?>
<!--
Backup + transfer rules. We exclude everything (no automatic cloud backup, no
device-to-device transfer of app data) because access + refresh tokens live in
flutter_secure_storage and must not leak via Google Auto Backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root"/>
        <exclude domain="file"/>
        <exclude domain="database"/>
        <exclude domain="sharedpref"/>
        <exclude domain="external"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root"/>
        <exclude domain="file"/>
        <exclude domain="database"/>
        <exclude domain="sharedpref"/>
        <exclude domain="external"/>
    </device-transfer>
</data-extraction-rules>
