<?xml version="1.0" encoding="utf-8"?>
<!-- RELEASE network security config: production must NEVER use cleartext.
     This file overrides src/main for release builds only (the debug build
     keeps the loopback dev hosts so the emulator can reach the local API). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
