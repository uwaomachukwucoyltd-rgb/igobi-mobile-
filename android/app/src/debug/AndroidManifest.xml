<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Debug-only manifest. Permits cleartext to localhost / the LAN dev IP
         so the debug build can talk to the unhosted backend. The release
         build inherits the locked-down network_security_config.xml in
         android/app/src/main/res/xml/. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <application
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config_debug"
        tools:replace="android:usesCleartextTraffic,android:networkSecurityConfig">
    </application>
</manifest>
